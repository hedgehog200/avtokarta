<Window x:Class="AVTOKarta.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AVTOKarta.Converters"
        xmlns:views="clr-namespace:AVTOKarta.Views"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xml:lang="ru-RU"
        Title="АВТОКарта v1.1.3 — WebARTup - Studio: Technologies" Height="750" Width="1150"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        KeyDown="Window_KeyDown"
        Icon="app.ico"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,16">
                    <TextBlock Text="АВТОКарта" Foreground="{StaticResource WhiteBrush}" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Учёт эксплуатации&#x0a;пожарных автомобилей" Foreground="{StaticResource PrimaryBrush}" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Squad selector -->
                <Border DockPanel.Dock="Top" Background="{StaticResource SidebarHoverBrush}" Margin="12,0,12,8" Padding="10"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Текущая часть:" Foreground="{StaticResource SidebarLabelBrush}" FontSize="10" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Squads}"
                                  SelectedItem="{Binding SelectedSquad}"
                                  FontSize="12"
                                  Style="{StaticResource SidebarComboBox}"
                                  ItemContainerStyle="{StaticResource ComboBoxItemStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Number}" Foreground="{StaticResource TextPrimaryBrush}" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Squad info (fixed bottom) -->
                <Border DockPanel.Dock="Bottom" Background="{StaticResource SidebarHoverBrush}" Margin="12,0,12,12" Padding="12"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="{Binding SquadName}" Foreground="{StaticResource WhiteBrush}" FontSize="13"
                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SquadNumber}" Foreground="{StaticResource WhiteBrush}" FontSize="12"
                                   Margin="0,2,0,0" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <!-- Navigation (scrollable) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              VerticalContentAlignment="Top">
                    <StackPanel Margin="8,0,8,0">
                        <TextBlock Text="НАВИГАЦИЯ" Foreground="{StaticResource SidebarLabelBrush}" FontSize="10" FontWeight="Bold"
                                   Margin="12,12,12,8"/>

                        <Button Command="{Binding SquadListCommand}" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#3F51B5" Margin="0,0,10,0">
                                    <TextBlock Text="&#x263A;" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Части" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding VehicleListCommand}" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#00897B" Margin="0,0,10,0">
                                    <TextBlock Text="&#x25CF;" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Автомобили" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding CardListCommand}" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#F4511E" Margin="0,0,10,0">
                                    <TextBlock Text="&#x25A0;" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Карточки" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding WarehouseCommand}" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#6A1B9A" Margin="0,0,10,0">
                                    <TextBlock Text="&#x25C6;" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Склад ГСМ" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SettingsCommand}" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#757575" Margin="0,0,10,0">
                                    <TextBlock Text="&#x2699;" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Настройки" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FuelReportCommand}" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#FB8C00" Margin="0,0,10,0">
                                    <TextBlock Text="&#x25B2;" FontSize="12" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Отчёт ГСМ" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="{StaticResource SidebarDividerBrush}" Margin="12,8,12,8"/>

                        <TextBlock Text="ДАННЫЕ" Foreground="{StaticResource SidebarLabelBrush}" FontSize="10" FontWeight="Bold"
                                   Margin="12,0,12,8"/>

                        <Button Command="{Binding ExportDataCommand}" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#43A047" Margin="0,0,10,0">
                                    <TextBlock Text="&#x2191;" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Выгрузка данных" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ImportDataCommand}" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#1E88E5" Margin="0,0,10,0">
                                    <TextBlock Text="&#x2193;" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Загрузка данных" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="{StaticResource SidebarDividerBrush}" Margin="12,12,12,8"/>

                        <Button Click="MenuItem_Exit_Click" Style="{StaticResource ExitButton}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="13" Background="#C62828" Margin="0,0,10,0">
                                    <TextBlock Text="&#x2716;" FontSize="12" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Выход" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP INFO BAR -->
            <Border Grid.Row="0" Background="{StaticResource WhiteBrush}" Padding="16,10"
                    BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{Binding SquadName}" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SquadNumber}" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentMonthYear}" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <Grid Grid.Row="1">
                    <!-- ЭКРАН НАСТРОЙКИ ЧАСТИ (первый запуск) -->
                    <views:SquadSetupView DataContext="{Binding SquadSetupVm}"
                                          Visibility="{Binding DataContext.IsSetupMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>

                    <!-- УПРАВЛЕНИЕ ЧАСТЯМИ -->
                    <views:SquadListView DataContext="{Binding}"
                                         Visibility="{Binding IsSquadListMode, Converter={StaticResource BoolToVis}}"/>

                    <!-- СПИСОК АВТОМОБИЛЕЙ -->
                    <DockPanel Visibility="{Binding IsVehicleMode, Converter={StaticResource BoolToVis}}">
                        <Border DockPanel.Dock="Top" Margin="16,12,16,8" Padding="16,12"
                                Style="{StaticResource CardBorderShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Справочник автомобилей" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="+ Добавить автомобиль"
                                        Command="{Binding AddVehicleCommand}"
                                        Style="{StaticResource SuccessButton}" Padding="14,8"/>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Column="0" ItemsSource="{Binding Vehicles}"
                                  SelectedItem="{Binding SelectedVehicle}" Margin="16,0,16,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Гос. знак" Binding="{Binding LicensePlate}" Width="100"/>
                                <DataGridTextColumn Header="Марка" Binding="{Binding Make}" Width="130"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="130"/>
                                <DataGridTextColumn Header="№ карточки" Binding="{Binding CardNumber}" Width="90"/>
                                <DataGridTextColumn Header="Пробег шасси (км)" Binding="{Binding InitialChassisMileage, StringFormat=N0}" Width="110"/>
                                <DataGridTextColumn Header="Пробег двиг. (км)" Binding="{Binding InitialEngineMileage, StringFormat=N0}" Width="110"/>
                                <DataGridTemplateColumn Header="Действия" Width="80" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="&#x270E;" Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.EditVehicleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" FontSize="14" Padding="6"
                                                        Foreground="{StaticResource PrimaryBrush}"/>
                                                <Button Content="&#x2716;" Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.DeleteVehicleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" FontSize="12" Padding="6"
                                                        Foreground="{StaticResource DangerBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <!-- ЭКРАН КАРТОЧКИ -->
                    <DockPanel Visibility="{Binding IsCardMode, Converter={StaticResource BoolToVis}}">
                        <Border DockPanel.Dock="Top" Margin="16,12,16,0" Padding="16,12"
                                Style="{StaticResource CardBorderShadow}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="16" FontWeight="Bold" VerticalAlignment="Center">
                                        <Run Text="ЭКСПЛУАТАЦИОННАЯ КАРТОЧКА"/>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1" Text="Месяц:" VerticalAlignment="Center"
                                               Margin="16,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding MonthNames}"
                                              SelectedIndex="{Binding SelectedMonthIndex}"
                                              Width="130" Margin="0,0,12,0"
                                              ItemContainerStyle="{StaticResource ComboBoxItemStyle}"/>

                                    <TextBlock Grid.Column="3" Text="Год:" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBox Grid.Column="4" Text="{Binding SelectedYear, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Авто:" FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                                    <ComboBox FontSize="12"
                                              ItemsSource="{Binding Vehicles}"
                                              SelectedItem="{Binding CardVehicle}"
                                              Width="180" HorizontalAlignment="Left"
                                              ItemContainerStyle="{StaticResource ComboBoxItemStyle}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding CardNumber}" FontWeight="SemiBold"/>
                                                    <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="{Binding Make, Mode=OneWay}"/>
                                                        <Run Text=" | "/>
                                                        <Run Text="{Binding LicensePlate, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock Margin="0,4,0,0" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="Марка: "/><Run Text="{Binding SelectedVehicleMake, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text="   Тип: "/><Run Text="{Binding SelectedVehicleType, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Top" Margin="16,8,16,0" Padding="16"
                                Style="{StaticResource CardBorderShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Пробег шасси на 1-е:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" IsReadOnly="True"
                                         Text="{Binding CurrentCard.ChassisMileageOnFirst, StringFormat=N0}"
                                         Background="{StaticResource PrimaryLightBrush}" Margin="2,4"/>
                                <Label Grid.Row="0" Grid.Column="2" Content="Пробег двиг. (прив.):"/>
                                <TextBox Grid.Row="0" Grid.Column="3" IsReadOnly="True"
                                         Text="{Binding CurrentCard.EngineMileageOnFirst, StringFormat=N0}"
                                         Background="{StaticResource PrimaryLightBrush}" Margin="2,4"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Остаток топлива на 1-е:"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding CurrentCard.FuelRemainingOnFirst, UpdateSourceTrigger=PropertyChanged}" Margin="2,4"/>
                                <Label Grid.Row="1" Grid.Column="2" Content="Заправлено за месяц:"/>
                                <TextBox Grid.Row="1" Grid.Column="3"
                                         Text="{Binding CurrentCard.FuelRefueledMonth, UpdateSourceTrigger=PropertyChanged}" Margin="2,4"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Остаток на конец:"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding CurrentCard.FuelRemainingOnLast, UpdateSourceTrigger=PropertyChanged}" Margin="2,4"/>
                                <Label Grid.Row="2" Grid.Column="2" Content="Уровень топлива (см):"/>
                                <TextBox Grid.Row="2" Grid.Column="3"
                                         Text="{Binding CurrentCard.FuelLevelCm, UpdateSourceTrigger=PropertyChanged}" Margin="2,4"/>

                                <Label Grid.Row="3" Grid.Column="0" Content="Способ поступления:"/>
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          SelectedIndex="{Binding DeliveryTypeIndex, Mode=TwoWay}"
                                          Margin="2,4" MinWidth="200">
                                    <ComboBoxItem Content="централизованно"/>
                                    <ComboBoxItem Content="по расчёту своего РЦ"/>
                                    <ComboBoxItem Content="по расчёту других РЦ"/>
                                    <ComboBoxItem Content="закуплено на местах"/>
                                    <ComboBoxItem Content="прочий приход"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border DockPanel.Dock="Bottom" Margin="16,8,16,8" Padding="16"
                                Style="{StaticResource CardBorderShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Button Content="+ Добавить запись" Command="{Binding AddRecordCommand}"
                                            Style="{StaticResource SuccessButton}" Padding="12,7" Margin="0,0,4,0"/>
                                    <Button Content="Редактировать" Command="{Binding EditRecordCommand}"
                                            Padding="12,7" Margin="4,0"/>
                                    <Button Content="Удалить" Command="{Binding DeleteRecordCommand}"
                                            Style="{StaticResource DangerButton}" Padding="12,7" Margin="4,0,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Content="Сохранить" Command="{Binding SaveCardCommand}"
                                            Style="{StaticResource SuccessButton}" Padding="12,7"/>
                                    <Button Content="Экспорт в Excel" Command="{Binding ExportExcelCommand}"
                                            Padding="12,7"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border DockPanel.Dock="Bottom" Margin="16,0,16,4" Padding="16"
                                Style="{StaticResource CardBorderShadow}">
                            <DockPanel MaxHeight="150">
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="История карточек" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <Button Content="Открыть" Command="{Binding OpenHistoryCardCommand}"
                                            Padding="10,4" FontSize="11" Margin="8,0,0,0"/>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding CardHistory}"
                                         SelectedItem="{Binding SelectedCardHistoryItem}"
                                         BorderThickness="0" Background="Transparent"
                                         DisplayMemberPath="MonthYearDisplay"/>
                            </DockPanel>
                        </Border>

                        <DataGrid Grid.Column="0" ItemsSource="{Binding Records}"
                                  SelectedItem="{Binding SelectedRecord}"
                                  Margin="16,0,16,0" CanUserAddRows="False"
                                  FontSize="11" RowHeaderWidth="0"
                                  AutoGenerateColumns="False"
                                  EnableRowVirtualization="False"
                                  CanUserResizeRows="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=d.M.yyyy}" Width="80" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Наименование и место работы автомобиля" Width="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                                                <TextBlock Text="{Binding WorkDescription}" TextWrapping="Wrap" FontSize="11" Padding="2"/>
                                            </ScrollViewer>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Примечание" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                                                <TextBlock Text="{Binding Comments}" TextWrapping="Wrap" FontSize="11" Padding="2"/>
                                            </ScrollViewer>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Выезд" Binding="{Binding DepartureTimeDisplay}" Width="55" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Возврат" Binding="{Binding ReturnTimeDisplay}" Width="55" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Спидометр, км" Binding="{Binding OdometerBeforeDeparture, StringFormat=N0}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Пробег км" Binding="{Binding DistanceKm, StringFormat=N1}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn Header="С насосом" Binding="{Binding TimeWithPumpMinutes, StringFormat=N0}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Без насоса (мин)" Binding="{Binding TimeWithoutPumpMinutes, StringFormat=N0}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Смена, мин." Binding="{Binding ShiftChangeMinutes, StringFormat=N0}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Прочие (мин)" Binding="{Binding MiscWorkMinutes, StringFormat=N0}" Width="55" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Расход" Width="55" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Факт" Binding="{Binding ActualConsumption, StringFormat=F3}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn Header="По норме" Binding="{Binding NormConsumption, StringFormat=F3}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Дежурный караул" Binding="{Binding SquadNumber}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Водитель" Binding="{Binding DriverName}" Width="80" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <!-- ЭКРАН НАСТРОЕК -->
                    <views:SettingsView DataContext="{Binding}"
                                        Visibility="{Binding IsSettingsMode, Converter={StaticResource BoolToVis}}"/>

                    <!-- ЭКРАН ОТЧЁТА ГСМ -->
                    <views:FuelReportView DataContext="{Binding}"
                                          Visibility="{Binding IsFuelReportMode, Converter={StaticResource BoolToVis}}"/>

                    <!-- ЭКРАН СКЛАДА ГСМ -->
                    <views:WarehouseView DataContext="{Binding}"
                                         Visibility="{Binding IsWarehouseMode, Converter={StaticResource BoolToVis}}"/>
                </Grid>

            <!-- BOTTOM: Status bar + Totals -->
            <Border Grid.Row="2" Background="{StaticResource WhiteBrush}" BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,1,0,0" Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                        <Run Text="WebARTup - Studio: Technologies разработал hedgehog200" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <Run Text="   |   "/>
                        <Run Text="{Binding StatusMessage, Mode=OneWay}"/>
                    </TextBlock>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding IsCardMode, Converter={StaticResource BoolToVis}}">
                        <Border Background="{StaticResource PillSuccessBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Факт: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding TotalActual, StringFormat=F2}" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text=" л" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PillPrimaryBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Норма: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding TotalNorm, StringFormat=F2}" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text=" л" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PillSuccessBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,6,0"
                                Visibility="{Binding SavingsVisibility}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Экономия: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding Savings, StringFormat=F2}" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text=" л" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PillWarningBrush}" CornerRadius="10" Padding="10,4"
                                Visibility="{Binding OverspendVisibility}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Перерасход: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding Overspend, StringFormat=F2}" FontWeight="Bold" FontSize="12"
                                           Foreground="{StaticResource DangerBrush}"/>
                                <TextBlock Text=" л" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>