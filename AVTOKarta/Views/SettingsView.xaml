<UserControl x:Class="AVTOKarta.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:AVTOKarta.Converters">
    <Border Style="{StaticResource CardBorderShadow}" Margin="20" Padding="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="500" HorizontalAlignment="Center">
                <TextBlock Text="Настройки текущей части" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

                <TextBlock Text="Наименование части:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox Text="{Binding SelectedSquad.Name, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Номер части:" FontWeight="SemiBold" Margin="0,8,0,2"/>
                <TextBox Text="{Binding SelectedSquad.Number, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Область / регион:" FontWeight="SemiBold" Margin="0,8,0,2"/>
                <TextBox Text="{Binding SelectedSquad.Region, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="ФИО начальника части:" FontWeight="SemiBold" Margin="0,8,0,2"/>
                <TextBox Text="{Binding SelectedSquad.ChiefName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="ФИО старшего водителя:" FontWeight="SemiBold" Margin="0,8,0,2"/>
                <TextBox Text="{Binding SelectedSquad.SeniorDriverName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Контактный телефон:" FontWeight="SemiBold" Margin="0,8,0,2"/>
                <TextBox Text="{Binding SelectedSquad.Phone, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Адрес расположения:" FontWeight="SemiBold" Margin="0,8,0,2"/>
                <TextBox Text="{Binding SelectedSquad.Address, UpdateSourceTrigger=PropertyChanged}"/>

                <Separator Margin="0,16"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Сохранить настройки" Command="{Binding SaveSettingsCommand}"
                            Style="{StaticResource SuccessButton}" Padding="14,8" Margin="0,0,8,0"/>
                    <Button Content="Сменить пароль" Command="{Binding ChangePasswordCommand}"
                            Padding="14,8"/>
                </StackPanel>

                <Border Style="{StaticResource InfoBanner}" Padding="12" Margin="0,8,0,16">
                    <StackPanel>
                        <TextBlock Text="Информация" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}">
                            Данные хранятся в зашифрованном виде в:
                            %LocalAppData%\AVTOKarta\Data\
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0">
                            Шифрование: AES-256 (CBC, PKCS7)
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Separator Margin="0,16"/>

                <TextBlock Text="Обновление приложения" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>

                <StackPanel DataContext="{Binding UpdateVM}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Текущая версия: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CurrentVersion}" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Visibility="{Binding RemoteVersion, Converter={x:Static local:NullOrEmptyToVisibilityConverter.Instance}}">
                        <TextBlock Text="Версия на сервере: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding RemoteVersion}" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusText}" Margin="0,0,0,8"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="{Binding IsDownloading, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                        <ProgressBar Value="{Binding DownloadProgress}" Maximum="100"
                                     Width="200" Height="6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DownloadProgressText}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Проверить обновления" Command="{Binding CheckUpdateCommand}"
                                Padding="14,8" Margin="0,0,8,0"
                                IsEnabled="{Binding CanCheck}"/>
                        <Button Content="Скачать и установить" Command="{Binding DownloadUpdateCommand}"
                                Padding="14,8" Visibility="{Binding HasUpdate, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                Style="{StaticResource SuccessButton}"
                                IsEnabled="{Binding CanCheck}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding PublishedAt}" Margin="0,0,0,4"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock Text="{Binding ReleaseNotes}" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="{Binding ReleaseNotes, Converter={x:Static local:NullOrEmptyToVisibilityConverter.Instance}}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>