<Window x:Class="AVTOKarta.Views.ChangePasswordView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Смена пароля" Height="320" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Border Margin="0" Background="White">
        <StackPanel Margin="24">
            <TextBlock Text="Смена пароля" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

            <TextBlock Text="Текущий пароль:" FontWeight="SemiBold"/>
            <hc:PasswordBox x:Name="OldPasswordBox" Margin="4,4,4,8" Height="32"/>

            <TextBlock Text="Новый пароль:" FontWeight="SemiBold"/>
            <hc:PasswordBox x:Name="NewPasswordBox" Margin="4,4,4,8" Height="32"/>

            <TextBlock Text="Подтвердите новый пароль:" FontWeight="SemiBold"/>
            <hc:PasswordBox x:Name="ConfirmPasswordBox" Margin="4,4,4,8" Height="32"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                       FontWeight="SemiBold" Margin="0,4" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Button Content="Отмена" Command="{Binding CancelCommand}" MinWidth="100"
                        Margin="0,0,8,0" Style="{StaticResource GhostButton}"
                        Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Content="Сменить" Command="{Binding ConfirmCommand}" MinWidth="100"
                        Style="{StaticResource SuccessButton}" Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>