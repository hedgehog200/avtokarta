<Window x:Class="AVTOKarta.Views.CardEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AVTOKarta.Converters"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xml:lang="ru-RU"
        Title="Ежедневная запись" Height="900" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <conv:IntStringConverter x:Key="IntStr"/>
        <conv:DoubleStringConverter x:Key="DoubleStr"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="TimeInput" TargetType="TextBox">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Border Background="White" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="12" Margin="8">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="20,14">
                <TextBlock Text="Ежедневная запись" FontSize="16" FontWeight="Bold" Foreground="White"/>
            </Border>

            <!-- Buttons -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Command="{Binding CancelCommand}" MinWidth="100" Margin="0,0,8,0"
                            Style="{StaticResource GhostButton}" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button Content="Сохранить" MinWidth="100"
                            Style="{StaticResource SuccessButton}" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel>
                    <!-- Date -->
                    <TextBlock Text="Дата" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Дата выезда:" Style="{StaticResource FieldLabel}"/>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding Date}" Margin="0" Padding="4,2"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="№ караула:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SquadNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ФИО водителя:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding DriverName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>

                    <!-- Work description -->
                    <TextBlock Text="Работа" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="№ путевого листа:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding TripSheetNumber, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" Margin="0" Padding="6,5"
                                 Background="{StaticResource BackgroundBrush}"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Наименование:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding WorkDescriptions}"
                                  Text="{Binding WorkDescription, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" Margin="0"
                                  MaxDropDownHeight="250"
                                  ItemContainerStyle="{StaticResource ComboBoxItemStyle}"/>
                    </Grid>

                    <!-- Comments (below Work) -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Подробности:" VerticalAlignment="Top"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,6,0,0"/>
                        <TextBox Grid.Column="1" Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" MaxHeight="80"
                                 VerticalScrollBarVisibility="Auto" Padding="6,4" Margin="0"
                                 ToolTip="Место работы, адрес, дополнительные сведения"/>
                    </Grid>

                    <Separator Background="{StaticResource DividerBrush}" Margin="0,6,0,12"/>

                    <!-- Time -->
                    <TextBlock Text="Время выезда и возвращения" Style="{StaticResource SectionTitle}"/>

                    <!-- Departure time -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Выезд:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding DepartureTime, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TimeInput}" MaxLength="5" Width="70"
                                 PreviewTextInput="TimeInput_PreviewTextInput"
                                 ToolTip="Формат: чч:мм (например 08:30)"/>
                        <TextBlock Grid.Column="2" Text="чч:мм" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="6,0,0,0"/>
                    </Grid>

                    <!-- Return time -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Возврат:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ReturnTime, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TimeInput}" MaxLength="5" Width="70"
                                 PreviewTextInput="TimeInput_PreviewTextInput"
                                 ToolTip="Формат: чч:мм (например 17:30)"/>
                        <TextBlock Grid.Column="2" Text="чч:мм" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="6,0,0,0"/>
                    </Grid>

                    <Separator Background="{StaticResource DividerBrush}" Margin="0,6,0,12"/>

                    <!-- Odometer + Distance -->
                    <TextBlock Text="Пробег" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Спидометр (км):" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding OdometerBeforeDeparture, UpdateSourceTrigger=LostFocus, Converter={StaticResource DoubleStr}}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Пробег (км):" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding DistanceKm, UpdateSourceTrigger=LostFocus, Converter={StaticResource DoubleStr}}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>

                    <Separator Background="{StaticResource DividerBrush}" Margin="0,6,0,12"/>

                    <!-- Work time -->
                    <TextBlock Text="Время работы (мин)" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="С насосом:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding TimeWithPumpMinutes, UpdateSourceTrigger=LostFocus, Converter={StaticResource DoubleStr}}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Без насоса:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding TimeWithoutPumpMinutes, UpdateSourceTrigger=LostFocus, Converter={StaticResource DoubleStr}}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Смена караула:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ShiftChangeMinutes, UpdateSourceTrigger=LostFocus, Converter={StaticResource DoubleStr}}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Прочие работы:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding MiscWorkMinutes, UpdateSourceTrigger=LostFocus, Converter={StaticResource DoubleStr}}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>

                    <Separator Background="{StaticResource DividerBrush}" Margin="0,6,0,12"/>

                    <!-- Fuel -->
                    <TextBlock Text="Топливо" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Заправка (л):" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding FuelRefueled, UpdateSourceTrigger=LostFocus, Converter={StaticResource DoubleStr}}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>

                    <!-- Norm result -->
                    <Border Style="{StaticResource InfoBanner}" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Расход по норме: " FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" FontSize="13"/>
                            <TextBlock Text="{Binding NormConsumption, Mode=OneWay, StringFormat=F2}"
                                       FontWeight="Bold" FontSize="14"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text=" л" Foreground="{StaticResource PrimaryBrush}" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Separator Background="{StaticResource DividerBrush}" Margin="0,6,0,12"/>

                    <!-- Masla / Smazki -->
                    <TextBlock Text="Масла и смазки" Style="{StaticResource SectionTitle}"/>

                    <!-- Add new entry -->
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                      ItemsSource="{Binding OilTypes}"
                                      SelectedItem="{Binding NewOilType}"
                                      DisplayMemberPath="Name"
                                      Margin="0" Padding="6,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Наименование:" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding NewOilName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0" Padding="6,4"
                                     ToolTip="Марка/название масла или смазки"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="+" MinWidth="36"
                                    Command="{Binding AddOilEntryCommand}"
                                    Style="{StaticResource SuccessButton}"/>
                        </Grid>
                    </Border>

                    <!-- Quantity row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Количество:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding NewOilQuantity, UpdateSourceTrigger=LostFocus, Converter={StaticResource DoubleStr}}"
                                 Margin="0" Padding="6,5"/>
                    </Grid>

                    <!-- Entries list -->
                    <ItemsControl ItemsSource="{Binding OilEntries}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="{StaticResource DividerBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TypeDisplay}" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Quantity, StringFormat=F2}" FontSize="12"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <Button Grid.Column="3" Content="×" MinWidth="28" FontSize="14"
                                                Command="{Binding DataContext.RemoveOilEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButton}" Foreground="{StaticResource DangerBrush}"
                                                Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>