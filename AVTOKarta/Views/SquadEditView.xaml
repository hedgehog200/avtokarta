<Window x:Class="AVTOKarta.Views.SquadEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Редактирование части" Height="470" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Border Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Margin="24">
            <TextBlock Text="Данные части" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>

            <TextBlock Text="Наименование части:" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Номер части:" FontWeight="SemiBold" Margin="0,8,0,2"/>
            <TextBox Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Номер отряда:" FontWeight="SemiBold" Margin="0,8,0,2"/>
            <TextBox Text="{Binding CrewNumber, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Область / регион:" FontWeight="SemiBold" Margin="0,8,0,2"/>
            <TextBox Text="{Binding Region, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="ФИО начальника части:" FontWeight="SemiBold" Margin="0,8,0,2"/>
            <TextBox Text="{Binding ChiefName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="ФИО старшего водителя:" FontWeight="SemiBold" Margin="0,8,0,2"/>
            <TextBox Text="{Binding SeniorDriverName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Контактный телефон:" FontWeight="SemiBold" Margin="0,8,0,2"/>
            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Адрес расположения:" FontWeight="SemiBold" Margin="0,8,0,2"/>
            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                       FontWeight="SemiBold" Margin="0,4" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Button Content="Отмена" Command="{Binding CancelCommand}" MinWidth="100"
                        Margin="0,0,8,0" Style="{StaticResource GhostButton}"
                        Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Content="Сохранить" MinWidth="100"
                        Style="{StaticResource SuccessButton}" Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Border>
</Window>