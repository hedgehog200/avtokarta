<UserControl x:Class="AVTOKarta.Views.WarehouseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xml:lang="ru-RU">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorderShadow}" Margin="16,12,16,8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Склад ГСМ (масла, смазки, спец. жидкости)" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0">
                        <Run Text="Полный учёт прихода, расхода и остатков"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ADD NEW ITEM FORM -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorderShadow}" Margin="16,0,16,8" Padding="16">
            <StackPanel>
                <TextBlock Text="Новое поступление" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Дата:" VerticalAlignment="Center"/>
                    <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding WarehouseVm.NewDate}"
                                Language="ru-RU" Margin="2,4" Width="150" HorizontalAlignment="Left"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="Тип ГСМ:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding WarehouseVm.OilTypes}"
                              SelectedValue="{Binding WarehouseVm.NewType}" SelectedValuePath="Type"
                              DisplayMemberPath="Name" Margin="2,4" Width="200" HorizontalAlignment="Left"
                              ItemContainerStyle="{StaticResource ComboBoxItemStyle}"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="Наименование/марка:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WarehouseVm.NewBrand, UpdateSourceTrigger=PropertyChanged}"
                             Margin="2,4" Width="200" HorizontalAlignment="Left"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="Количество:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding WarehouseVm.NewQuantity, UpdateSourceTrigger=PropertyChanged}"
                             Margin="2,4" Width="100" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="№ накладной:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding WarehouseVm.NewDocumentNumber, UpdateSourceTrigger=PropertyChanged}"
                             Margin="2,4" Width="150" HorizontalAlignment="Left"/>
                    <Label Grid.Column="2" Content="Поставщик:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="3" Text="{Binding WarehouseVm.NewSupplier, UpdateSourceTrigger=PropertyChanged}"
                             Margin="2,4" Width="200" HorizontalAlignment="Left"/>
                    <Button Grid.Column="4" Content="+ Добавить" Command="{Binding WarehouseVm.AddCommand}"
                            Style="{StaticResource SuccessButton}" Padding="14,8" Margin="8,4,0,4"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- TOTALS -->
        <Border DockPanel.Dock="Top" Style="{StaticResource InfoBanner}" Margin="16,0,16,8" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Border Background="{StaticResource PillPrimaryBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Моторное масло: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding WarehouseVm.TotalMotorOil, StringFormat=F2}" FontWeight="Bold" FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text=" л" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PillPrimaryBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Трансм. масло: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding WarehouseVm.TotalTransOil, StringFormat=F2}" FontWeight="Bold" FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text=" л" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PillPrimaryBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Спец. жидкость: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding WarehouseVm.TotalSpecLiquid, StringFormat=F2}" FontWeight="Bold" FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text=" л" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PillPrimaryBrush}" CornerRadius="10" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Пласт. смазка: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding WarehouseVm.TotalPlasticLub, StringFormat=F2}" FontWeight="Bold" FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text=" кг" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- DELETE BUTTON -->
        <Border DockPanel.Dock="Bottom" Margin="16,0,16,12" Padding="8,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="Удалить выбранное" Command="{Binding WarehouseVm.DeleteCommand}"
                        Style="{StaticResource DangerButton}" Padding="12,7"/>
            </StackPanel>
        </Border>

        <!-- ITEMS TABLE -->
        <DataGrid ItemsSource="{Binding WarehouseVm.Items}"
                  SelectedItem="{Binding WarehouseVm.SelectedItem}"
                  Margin="16,0,16,0" CanUserAddRows="False"
                  FontSize="12" RowHeaderWidth="0"
                  AutoGenerateColumns="False"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True"
                  CanUserResizeRows="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=d.M.yyyy}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Тип ГСМ" Binding="{Binding TypeDisplay}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Наименование/марка" Binding="{Binding Brand}" Width="160" IsReadOnly="True"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=F2}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ед. изм." Binding="{Binding UnitDisplay}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="№ накладной" Binding="{Binding DocumentNumber}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier}" Width="140" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="" Width="40" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="x" Style="{StaticResource IconButton}"
                                    Command="{Binding DataContext.WarehouseVm.RemoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" FontSize="11" Padding="4"
                                    Foreground="{StaticResource DangerBrush}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
