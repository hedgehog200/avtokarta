<UserControl x:Class="AVTOKarta.Views.FuelReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorderShadow}" Margin="16,12,16,8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Отчёт движения ГСМ" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0">
                        <Run Text="Часть: "/><Run Text="{Binding SquadName, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Период:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding MonthNames}"
                                  SelectedIndex="{Binding SelectedMonthIndex, Mode=TwoWay}"
                                  Width="150" FontSize="12" Margin="0,0,12,0"/>
                        <hc:NumericUpDown Value="{Binding SelectedYear, Mode=TwoWay}"
                                          Minimum="2020" Maximum="2040" Width="80"
                                          FontSize="12" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding CurrentMonthYear, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="Экспорт в Excel"
                        Command="{Binding ExportFuelReportCommand}"
                        Style="{StaticResource SuccessButton}" Padding="14,8" VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Style="{StaticResource InfoBanner}" Margin="16,0,16,8" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Автомобили, включённые в отчёт:" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <TextBlock Text="Отчёт формируется на основе эксплуатационных карточек всех автомобилей текущей части за выбранный период."
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Column="0" ItemsSource="{Binding Vehicles}"
                  Margin="16,0,16,8" CanUserAddRows="False"
                  IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Гос. знак" Binding="{Binding LicensePlate}" Width="100"/>
                <DataGridTextColumn Header="Марка" Binding="{Binding Make}" Width="150"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="150"/>
                <DataGridTextColumn Header="№ карточки" Binding="{Binding CardNumber}" Width="90"/>
                <DataGridTextColumn Header="Норма л/км" Binding="{Binding FuelNorms.ConsumptionPerKmWithoutPump, StringFormat=F2}" Width="80"/>
                <DataGridTextColumn Header="Норма л/мин (насос)" Binding="{Binding FuelNorms.ConsumptionPerMinPump, StringFormat=F2}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource InfoBanner}" Margin="16,0,16,12" Padding="16,12">
            <TextBlock FontSize="11" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="Файл: "/>
                <Run Text="Отчет_ГСМ_{месяц}_{год}.xlsx" FontWeight="SemiBold"/>
                <Run Text="  —  сохраняется в папку «Документы»"/>
            </TextBlock>
        </Border>
    </DockPanel>
</UserControl>